---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icon-192x192.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="LinguAI Studio - Professional AI-powered text rewriting with multiple styles and languages" />
    <meta name="theme-color" content="#1d4ed8" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="LinguAI" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="generator" content={Astro.generator} />
    <title>LinguAI Studio — AI Text Rewriter</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- ===== NAVBAR ===== -->
    <header class="nb-navbar" id="navbar">
      <div class="nb-nav-inner">

        <a href="/" class="nb-logo">
          <img src="/favicon.svg" alt="LinguAI Logo" class="nb-logo-img" />
          <span class="nb-logo-text">LinguAI</span>
          <span class="nb-logo-badge">STUDIO</span>
        </a>

        <nav class="nb-nav-links" aria-label="Main navigation">
          <a href="#features" class="nb-nav-link">Features</a>
          <a href="#how-it-works" class="nb-nav-link">How It Works</a>
          <a href="#faq" class="nb-nav-link">FAQ</a>
        </nav>

        <div class="nb-nav-actions">
          <a href="/app" class="nb-btn-solid">Get Started</a>
        </div>

        <button class="nb-hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="2" y1="6" x2="20" y2="6" class="ham-top" />
            <line x1="2" y1="11" x2="20" y2="11" class="ham-mid" />
            <line x1="2" y1="16" x2="20" y2="16" class="ham-bot" />
          </svg>
        </button>
      </div>

      <div class="nb-mobile-nav" id="mobileNav" aria-hidden="true">
        <a href="#features" class="nb-mobile-link">Features</a>
        <a href="#how-it-works" class="nb-mobile-link">How It Works</a>
        <a href="#faq" class="nb-mobile-link">FAQ</a>
        <a href="/app" class="nb-btn-solid" style="text-align:center; margin-top: 0.5rem;">Get Started</a>
      </div>
    </header>

    <!-- ===== HERO ===== -->
    <section class="nb-hero">
      <div class="nb-hero-inner">

        <!-- Left: Text -->
        <div class="nb-hero-text">
          <div class="nb-hero-tag">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            AI-Powered · Multi-Language · Instant
          </div>

          <h1 class="nb-hero-title">
            Here <span class="text-blue-600">writers</span><br/>
            make 
            <span class="nb-highlight-box">awesome</span>
          </h1>

          <p class="nb-hero-sub">
            LinguAI Studio transforms your content instantly. Choose tone,
            style, and language to create perfectly tailored text — free, no sign-up.
          </p>

          <div class="nb-hero-btns">
            <a href="/app" class="nb-btn-solid nb-btn-lg">
              Get Started Free
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#features" class="nb-btn-outline nb-btn-lg">
              See Features
            </a>
          </div>

          <div class="nb-hero-stats">
            <div class="nb-stat">
              <span class="nb-stat-n">10+</span>
              <span class="nb-stat-l">Tone Styles</span>
            </div>
            <div class="nb-stat-sep"></div>
            <div class="nb-stat">
              <span class="nb-stat-n">5+</span>
              <span class="nb-stat-l">Languages</span>
            </div>
            <div class="nb-stat-sep"></div>
            <div class="nb-stat">
              <span class="nb-stat-n">PWA</span>
              <span class="nb-stat-l">Works Offline</span>
            </div>
          </div>
        </div>

        <!-- Right: App Preview -->
        <div class="nb-hero-visual">
          <div class="nb-app-card">
            <div class="nb-card-topbar">
              <div class="nb-dots">
                <span class="nb-dot nb-dot-r"></span>
                <span class="nb-dot nb-dot-y"></span>
                <span class="nb-dot nb-dot-g"></span>
              </div>
              <span class="nb-card-title">LinguAI Studio</span>
              <span class="nb-card-badge">PWA</span>
            </div>

            <div class="nb-card-body">
              <div class="nb-preview-section">
                <div class="nb-preview-label">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                  </svg>
                  Input Text
                </div>
                <div class="nb-preview-box">
                  <div class="nb-line" style="width:88%"></div>
                  <div class="nb-line" style="width:72%"></div>
                  <div class="nb-line" style="width:81%"></div>
                </div>
              </div>

              <div class="nb-preview-pills">
                <span class="nb-pill nb-pill-active">Professional</span>
                <span class="nb-pill">Creative</span>
                <span class="nb-pill">Concise</span>
                <span class="nb-pill">English</span>
              </div>

              <button class="nb-generate-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                Generate with AI
              </button>

              <div class="nb-preview-section">
                <div class="nb-preview-label nb-label-out">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  AI Output
                  <span class="nb-done-badge">Done</span>
                </div>
                <div class="nb-preview-box nb-preview-box-out">
                  <div class="nb-line nb-line-out" style="width:94%"></div>
                  <div class="nb-line nb-line-out" style="width:79%"></div>
                  <div class="nb-line nb-line-out" style="width:86%"></div>
                </div>
              </div>
            </div>
          </div>

          <div class="nb-float-tag nb-float-tl">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Lightning Fast
          </div>
          <div class="nb-float-tag nb-float-br">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>
            Multi-Language
          </div>
        </div>

      </div>
    </section>

    <!-- ===== FEATURES ===== -->
    <section id="features" class="nb-section nb-section-alt">
      <div class="nb-container">
        <div class="nb-section-head">
          <div class="nb-section-tag">Powerful Features</div>
          <h2 class="nb-section-title">Everything you need<br/>to write better</h2>
          <p class="nb-section-desc">Professional AI rewriting tools, all in one place.</p>
        </div>

        <div class="nb-features-grid">

          <div class="nb-feat-card nb-feat-accent">
            <div class="nb-feat-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
              </svg>
            </div>
            <h3 class="nb-feat-title">Multiple Tones</h3>
            <p class="nb-feat-desc">Professional, casual, formal, or creative. Choose the perfect tone for any situation.</p>
            <div class="nb-feat-tags">
              <span class="nb-tag">Professional</span>
              <span class="nb-tag">Creative</span>
              <span class="nb-tag">Formal</span>
              <span class="nb-tag">Casual</span>
            </div>
          </div>

          <div class="nb-feat-card">
            <div class="nb-feat-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M9 9h6M9 12h6M9 15h4"/>
              </svg>
            </div>
            <h3 class="nb-feat-title">Writing Styles</h3>
            <p class="nb-feat-desc">Concise, elaborate, or balanced. Adapt your content length to fit your needs.</p>
          </div>

          <div class="nb-feat-card">
            <div class="nb-feat-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/>
              </svg>
            </div>
            <h3 class="nb-feat-title">Multi-Language</h3>
            <p class="nb-feat-desc">English, Indonesian, Spanish, and more. Break language barriers effortlessly.</p>
          </div>

          <div class="nb-feat-card">
            <div class="nb-feat-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            </div>
            <h3 class="nb-feat-title">Lightning Fast</h3>
            <p class="nb-feat-desc">Get AI results in seconds, powered by state-of-the-art models for real-time output.</p>
          </div>

          <div class="nb-feat-card">
            <div class="nb-feat-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3 class="nb-feat-title">Progressive Web App</h3>
            <p class="nb-feat-desc">Install on any device, works offline. Access your texts anytime, anywhere.</p>
          </div>

          <div class="nb-feat-card nb-feat-dark">
            <div class="nb-feat-icon nb-feat-icon-inv">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
              </svg>
            </div>
            <h3 class="nb-feat-title">Private & Secure</h3>
            <p class="nb-feat-desc">Your data stays on your device. No tracking, no ads — complete privacy.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== HOW IT WORKS ===== -->
    <section id="how-it-works" class="nb-section">
      <div class="nb-container">
        <div class="nb-section-head">
          <div class="nb-section-tag">Simple Process</div>
          <h2 class="nb-section-title">Three steps to<br/>perfect content</h2>
        </div>

        <div class="nb-steps">

          <div class="nb-step">
            <div class="nb-step-num">01</div>
            <div class="nb-step-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
            </div>
            <h3 class="nb-step-title">Enter Your Text</h3>
            <p class="nb-step-desc">Paste or type your content into the editor. Supports any format or length up to 5000 characters.</p>
          </div>

          <div class="nb-step-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>

          <div class="nb-step nb-step-featured">
            <div class="nb-step-num">02</div>
            <div class="nb-step-icon nb-step-icon-feat">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/>
              </svg>
            </div>
            <h3 class="nb-step-title">Choose Settings</h3>
            <p class="nb-step-desc">Pick your tone, writing style, and target language. Add custom instructions if needed.</p>
          </div>

          <div class="nb-step-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>

          <div class="nb-step">
            <div class="nb-step-num">03</div>
            <div class="nb-step-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            </div>
            <h3 class="nb-step-title">Generate & Copy</h3>
            <p class="nb-step-desc">Click Generate for instant AI transformation. Copy and use your perfect text right away.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== CTA STRIP ===== -->
    <section class="nb-cta">
      <div class="nb-cta-inner">
        <div class="nb-cta-left">
          <div class="nb-cta-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <div>
            <h2 class="nb-cta-title">We help you write<br/>the best text — with AI</h2>
            <p class="nb-cta-desc">Start transforming your writing today. Free, no sign-up required, works on any device.</p>
          </div>
        </div>
        <a href="/app" class="nb-btn-solid nb-btn-lg nb-btn-white">
          Launch App
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section id="faq" class="nb-section nb-section-alt">
      <div class="nb-container">
        <div class="nb-section-head">
          <div class="nb-section-tag">FAQ</div>
          <h2 class="nb-section-title">Frequently asked<br/>questions</h2>
        </div>

        <div class="nb-faq-tabs" role="tablist">
          <button class="nb-tab nb-tab-active" data-tab="general" role="tab" aria-selected="true">General</button>
          <button class="nb-tab" data-tab="features" role="tab" aria-selected="false">Features</button>
          <button class="nb-tab" data-tab="pricing" role="tab" aria-selected="false">Pricing</button>
        </div>

        <div class="nb-faq-list" id="faqList">

          <div class="nb-faq-item" data-category="general">
            <button class="nb-faq-q" aria-expanded="false">
              <span>How does LinguAI work?</span>
              <svg class="nb-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="nb-faq-a">
              <p>LinguAI uses state-of-the-art AI language models to understand and rewrite your text in the style, tone, and language you choose. Simply input your content, pick your preferences, and click Generate.</p>
            </div>
          </div>

          <div class="nb-faq-item" data-category="general">
            <button class="nb-faq-q" aria-expanded="false">
              <span>Is it really free?</span>
              <svg class="nb-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="nb-faq-a">
              <p>Yes — the core AI rewriting features are completely free with no sign-up required. Future premium plans will unlock higher limits and advanced features for power users.</p>
            </div>
          </div>

          <div class="nb-faq-item" data-category="general">
            <button class="nb-faq-q" aria-expanded="false">
              <span>Which platforms are supported?</span>
              <svg class="nb-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="nb-faq-a">
              <p>As a Progressive Web App (PWA), LinguAI Studio works on all platforms — Windows, macOS, Linux, iOS, and Android. Install it from your browser for offline access.</p>
            </div>
          </div>

          <div class="nb-faq-item" data-category="features">
            <button class="nb-faq-q" aria-expanded="false">
              <span>What languages are supported?</span>
              <svg class="nb-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="nb-faq-a">
              <p>We support English, Indonesian, Spanish, French, German, and more. New languages are added regularly based on community demand.</p>
            </div>
          </div>

          <div class="nb-faq-item" data-category="features">
            <button class="nb-faq-q" aria-expanded="false">
              <span>Can I add custom instructions?</span>
              <svg class="nb-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="nb-faq-a">
              <p>Yes! The Settings panel includes a Custom Instruction field where you can add special instructions for the AI — like "keep bullet points" or "use simple words".</p>
            </div>
          </div>

          <div class="nb-faq-item" data-category="pricing">
            <button class="nb-faq-q" aria-expanded="false">
              <span>Will there be a paid plan?</span>
              <svg class="nb-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="nb-faq-a">
              <p>We plan to introduce an optional Pro plan with higher usage limits, priority processing, and advanced customization. The core free plan will always remain free.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="nb-footer">
      <div class="nb-container">
        <div class="nb-footer-grid">

          <div class="nb-footer-brand">
            <a href="/" class="nb-logo">
              <img src="/favicon.svg" alt="LinguAI Logo" class="nb-logo-img" />
              <span class="nb-logo-text">LinguAI</span>
              <span class="nb-logo-badge">STUDIO</span>
            </a>
            <p class="nb-footer-desc">Professional AI-powered text rewriting for everyone. Fast, private, and powerful.</p>
            <div class="nb-footer-socials">
              <a href="https://x.com/tyodev" aria-label="Twitter" class="nb-social-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="https://github.com/catursetyono" aria-label="GitHub" class="nb-social-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              </a>
            </div>
          </div>

          <div>
            <h4 class="nb-footer-heading">Product</h4>
            <ul class="nb-footer-links">
              <li><a href="/app" class="nb-footer-link">App</a></li>
              <li><a href="#features" class="nb-footer-link">Features</a></li>
              <li><a href="#how-it-works" class="nb-footer-link">How It Works</a></li>
            </ul>
          </div>

          <div>
            <h4 class="nb-footer-heading">Info</h4>
            <ul class="nb-footer-links">
              <li><span class="nb-footer-text">PWA Enabled</span></li>
              <li><span class="nb-footer-text">Privacy First</span></li>
              <li><span class="nb-footer-text">Open Source</span></li>
            </ul>
          </div>

          <div>
            <h4 class="nb-footer-heading">Support</h4>
            <ul class="nb-footer-links">
              <li><a href="#faq" class="nb-footer-link">FAQ</a></li>
              <li><a href="/app" class="nb-footer-link">Documentation</a></li>
            </ul>
          </div>

        </div>

        <div class="nb-footer-bottom">
          <p>© 2026 LinguAI Studio. Built with care and AI.</p>
          <div class="nb-footer-bottom-links">
            <a href="#" class="nb-footer-link">Privacy</a>
            <a href="#" class="nb-footer-link">Terms</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // PWA
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }

      // Sticky navbar
      const navbar = document.getElementById('navbar');
      window.addEventListener('scroll', () => {
        navbar?.classList.toggle('nb-navbar-scrolled', window.scrollY > 20);
      });

      // Mobile menu
      const hamburger = document.getElementById('hamburger');
      const mobileNav = document.getElementById('mobileNav');
      hamburger?.addEventListener('click', () => {
        const open = mobileNav?.classList.toggle('nb-mobile-open');
        hamburger.setAttribute('aria-expanded', open ? 'true' : 'false');
        mobileNav?.setAttribute('aria-hidden', open ? 'false' : 'true');
      });

      // Close mobile nav on link click
      mobileNav?.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          mobileNav.classList.remove('nb-mobile-open');
          hamburger?.setAttribute('aria-expanded', 'false');
          mobileNav.setAttribute('aria-hidden', 'true');
        });
      });

      // FAQ accordion
      document.querySelectorAll('.nb-faq-q').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.nb-faq-item');
          const isOpen = item?.classList.contains('nb-faq-open');
          // close all
          document.querySelectorAll('.nb-faq-item').forEach(i => {
            i.classList.remove('nb-faq-open');
            i.querySelector('.nb-faq-q')?.setAttribute('aria-expanded', 'false');
          });
          // open if it was closed
          if (!isOpen) {
            item?.classList.add('nb-faq-open');
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });

      // FAQ tabs
      document.querySelectorAll('.nb-tab').forEach(tab => {
        tab.addEventListener('click', () => {
          document.querySelectorAll('.nb-tab').forEach(t => {
            t.classList.remove('nb-tab-active');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('nb-tab-active');
          tab.setAttribute('aria-selected', 'true');
          const cat = (tab as HTMLElement).dataset.tab;
          document.querySelectorAll('.nb-faq-item').forEach(item => {
            const el = item as HTMLElement;
            el.style.display = (cat === 'general' || el.dataset.category === cat) ? '' : 'none';
          });
        });
      });

      // Scroll animations
      const io = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('nb-visible'); });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.nb-animate').forEach(el => io.observe(el));
    </script>

  </body>
</html>
