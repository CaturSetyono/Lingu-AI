---
export const prerender = true;
import { App as AppComponent } from '../components/App';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="LinguAI Studio — AI-powered text rewriting PWA. Choose tone, style, and language." />
    <meta name="theme-color" content="#1d4ed8" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="generator" content={Astro.generator} />
    <title>LinguAI Studio — AI Text Rewriter App</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>

  <body class="app-page">

    <!-- NAV -->
    <header class="app-header" id="appHeader">
      <div class="app-header-inner">
        <a href="/" class="nb-logo">
          <img src="/favicon.svg" alt="LinguAI Logo" class="nb-logo-img" />
          <span class="nb-logo-text">LinguAI</span>
          <span class="nb-logo-badge">STUDIO</span>
        </a>

        <div class="app-header-right">
          <span class="app-pwa-badge">PWA</span>
        </div>
      </div>
    </header>

    <!-- MAIN APP -->
    <main class="app-main">
      <div class="app-wrapper">
        <div class="app-page-header">
          <h1 class="app-page-title">
            AI Text
            <span class="app-title-accent">Rewriter</span>
          </h1>
          <p class="app-page-desc">Paste your text, choose your settings, and let AI transform it instantly.</p>
        </div>

        <AppComponent client:load />
      </div>
    </main>

    <!-- FOOTER -->
    <footer class="app-footer">
      <div class="app-footer-inner">
        <p class="app-footer-text">LinguAI Studio &copy; 2026 — Built with AI</p>
        <a href="/" class="app-footer-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Back to Home
        </a>
      </div>
    </footer>

    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }

      // Sticky header shadow
      const header = document.getElementById('appHeader');
      window.addEventListener('scroll', () => {
        header?.classList.toggle('app-header-stuck', window.scrollY > 10);
      });
    </script>

  </body>
</html>

<style>
  /* App-page specific styles */
  .app-page {
    background: #f5f5f0;
    min-height: 100vh;
  }

  .app-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #f5f5f0;
    border-bottom: 2px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }
  .app-header-stuck {
    border-bottom-color: #0d0d0d;
    background: #ffffff;
  }

  .app-header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .app-header-right {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .app-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #6b7280;
    border: 2px solid transparent;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    transition: all 0.15s;
  }
  .app-back-link:hover {
    color: #0d0d0d;
    border-color: #0d0d0d;
    background: #fff;
  }

  .app-pwa-badge {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    background: #1d4ed8;
    color: #fff;
    padding: 3px 8px;
    border-radius: 4px;
    border: 2px solid #0d0d0d;
  }

  .app-main {
    padding: 2.5rem 1.5rem 5rem;
  }

  .app-wrapper {
    max-width: 860px;
    margin: 0 auto;
  }

  .app-page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid #0d0d0d;
  }

  .app-page-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #0d0d0d;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .app-title-accent {
    display: inline-block;
    background: #1d4ed8;
    color: #ffffff;
    padding: 0.05em 0.25em;
    border-radius: 4px;
    border: 2px solid #0d0d0d;
  }

  .app-page-desc {
    font-size: 0.95rem;
    color: #6b7280;
    line-height: 1.6;
  }

  .app-footer {
    border-top: 2px solid #0d0d0d;
    padding: 1.25rem 1.5rem;
    background: #0d0d0d;
  }

  .app-footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .app-footer-text {
    font-size: 0.8rem;
    color: #6b7280;
  }

  .app-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #9ca3af;
    transition: color 0.15s;
  }
  .app-footer-link:hover { color: #ffffff; }
</style>
